# Get a key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=....

# Embedding backend:
# - local  -> no embedding API quota usage (recommended for demos)
# - gemini -> Gemini embedding API (uses quota)
EMBEDDING_BACKEND=local

